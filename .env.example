# Required: PostHog personal API key with session_recording:read.
POSTHOG_PERSONAL_API_KEY=

# Optional: project ID. If omitted, the app picks the first project visible to the key,
# or matches POSTHOG_PROJECT_TOKEN when provided.
POSTHOG_PROJECT_ID=
POSTHOG_PROJECT_TOKEN=
POSTHOG_API_HOST=https://us.posthog.com

# Required for analysis.
# Use "ai-studio" for GOOGLE_AI_API_KEY, or "vertex-ai" for GCP Vertex AI.
GEMINI_PROVIDER=ai-studio
GOOGLE_AI_API_KEY=
GEMINI_REPLAY_MODEL=gemini-3.5-flash

# Optional: password-gate the web UI, API, and generated replay artifacts.
REPLAY_LENS_PASSWORD=

# Optional: Vertex AI / GCP mode. VERTEX_AI_ACCESS_TOKEN may be omitted when
# local gcloud application-default credentials are available.
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=global
VERTEX_AI_ACCESS_TOKEN=

# Runtime knobs.
PORT=8787
POSTHOG_SNAPSHOT_CHUNK_SIZE=20
POSTHOG_MAX_THROTTLE_WAIT_SECONDS=0
